<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ApplicationIcon>Assets\Icons\app-image.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Assets\Icons\*.png" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\Icons\*.ico" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="Assets\Icons\*_LICENSE.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
